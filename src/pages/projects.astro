---
import Layaout from "../layouts/Layout.astro";
import { projects } from "../constants/projects";
import { Icon } from "astro-icon/components";
---

<Layaout
  title="Proyectos"
  description="Explora mis proyectos y trabajos anteriores como desarrollador web."
>
  <div class="w-full max-w-[1400px] auto-rows-[30rem] gap-4 px-4 py-8 sm:py-4 mx-auto">
    <ul class="gap-4 grid lg:grid-cols-3 md:grid-cols-2 not-sm:grid-cols-1 mx-auto">
      {
        projects.map((project) => (
          <li>
            <article  class="p-4 hover:border-blue-500 hover:border-1 rounded-lg text-white  relative flex flex-col justify-between items-start gap-2 group">
              <h2 class="font-bold text-white text-2xl">{project.title}</h2>
              <p>{project.description}</p>
                <a 
                class="flex border rounded-lg p-2 transition-transform duration-300 ease-in-out group-hover:scale-105" 
                href={project.link} 
                target="_blank" 
                rel="noopener noreferrer"
                >
                  <Icon name="mdi:open-in-new" class="w-6 h-6 mr-1" />
                  Ver Proyecto
                </a>
            </article>
          </li>
        ))
      }
    </ul>
  </div>
</Layaout>
