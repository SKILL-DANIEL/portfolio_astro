---
import { Icon } from "astro-icon/components";
const { project } = Astro.props;
---

<li data-aos="zoom-in">
  <article
    class="p-4 hover:border-blue-500 hover:border-1 rounded-2xl shadow-lg text-white relative flex flex-col justify-between items-start gap-2 group"
  >
    <h2 class="font-bold text-white text-2xl">{project.title}</h2>
    <p>{project.description}</p>

    <a
      class="flex border rounded-lg p-2 transition-transform duration-300 ease-in-out group-hover:scale-105"
      href={project.link}
      target="_blank"
      rel="noopener noreferrer"
    >
      <Icon name="mdi:open-in-new" class="w-6 h-6 mr-1" />
      Ver Proyecto
    </a>
  </article>
</li>
