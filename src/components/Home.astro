---
import { Icon } from "astro-icon/components";
---

<section
  data-aos="zoom-in"
  class="mb-3-16 px-4 relative overflow-hidden rounded-3xl shadow-xl
    bg-gradient-to-br
    from-[oklch(0.18_0.02_285.823)]
    via-[oklch(0.35_0.04_285.823)]
    to-[oklch(0.55_0.08_285.823)]"
>
  <div
    class="max-w-2xl mx-auto py-16 flex flex-col items-center text-center text-white relative z-10"
  >
    <img
      src="/profile.jpg"
      alt="Mi foto"
      class="w-32 h-32 rounded-full mx-auto mb-6 border-4 border-white shadow-lg"
    />
    <h1 class="text-4xl font-extrabold mb-4 drop-shadow-lg">
      Hola, soy Daniel Ospina
    </h1>
    <p class="text-lg mb-6">Ingeniero de Sistema especializado en:</p>
    <div class="flex flex-wrap justify-center gap-1 mb-8">
      <a
        class="p-2 border border-orange-500 rounded-md flex items-center justify-center hover-3d"
        title="HTML5"
      >
        <Icon
          name="devicon:html5"
          class="text-orange-500 w-10 h-10 transition-transform duration-300 transform hover:scale-110 cursor-pointer"
        />
      </a>
      <a
        class="p-2 border border-cyan-400 rounded-md flex items-center justify-center hover-3d"
        title="CSS3"
      >
        <Icon
          name="devicon:css3"
          class="text-cyan-400 w-10 h-10 transition-transform duration-300 transform hover:scale-110 cursor-pointer"
        />
      </a>
      <a
        class="p-2 border border-yellow-400 rounded-md flex items-center justify-center hover-3d"
        title="JavaScript"
      >
        <Icon
          name="mdi:language-javascript"
          class="text-yellow-400 w-10 h-10 transition-transform duration-300 transform hover:scale-110 cursor-pointer"
        />
      </a>
      <a
        class="p-2 border border-blue-500 rounded-md flex items-center justify-center hover-3d"
        title="TypeScript"
      >
        <Icon
          name="devicon:typescript"
          class="text-blue-500 w-10 h-10 transition-transform duration-300 transform hover:scale-110 cursor-pointer"
        />
      </a>
      <a
        class="p-2 border border-indigo-400 rounded-md flex items-center justify-center hover-3d"
        title="PHP"
      >
        <Icon
          name="devicon:php"
          class="text-indigo-400 w-10 h-10 transition-transform duration-300 transform hover:scale-110 cursor-pointer"
        />
      </a>
      <a
        class="p-2 border border-cyan-400 rounded-md flex items-center justify-center hover-3d"
        title="React"
      >
        <Icon
          name="devicon:react-wordmark"
          class="text-cyan-400 w-10 h-10 transition-transform duration-300 transform hover:scale-110 cursor-pointer"
        />
      </a>
      <a
        class="p-2 border border-blue-400 rounded-md flex items-center justify-center hover-3d"
        title="React Native"
      >
        <Icon
          name="devicon:reactnative-wordmark"
          class="text-blue-400 w-10 h-10 transition-transform duration-300 transform hover:scale-110 cursor-pointer"
        />
      </a>
      <a
        class="p-2 border border-green-500 rounded-md flex items-center justify-center hover-3d"
        title="Node.js"
      >
        <Icon
          name="mdi:nodejs"
          class="text-green-500 w-10 h-10 transition-transform duration-300 transform hover:scale-110 cursor-pointer"
        />
      </a>
      <a
        class="p-2 border border-red-500 rounded-md flex items-center justify-center hover-3d"
        title="Laravel"
      >
        <Icon
          name="mdi:laravel"
          class="text-red-500 w-10 h-10 transition-transform duration-300 transform hover:scale-110 cursor-pointer"
        />
      </a>
      <a
        class="p-2 border border-yellow-500 rounded-md flex items-center justify-center hover-3d"
        title="Python"
      >
        <Icon
          name="devicon:python"
          class="text-yellow-500 w-10 h-10 transition-transform duration-300 transform hover:scale-110 cursor-pointer"
        />
      </a>
      <a
        class="p-2 border border-orange-600 rounded-md flex items-center justify-center hover-3d"
        title="Git"
      >
        <Icon
          name="devicon:git"
          class="text-orange-600 w-10 h-10 transition-transform duration-300 transform hover:scale-110 cursor-pointer"
        />
      </a>
      <a
        class="p-2 border border-blue-400 rounded-md flex items-center justify-center hover-3d"
        title="Bases de datos"
      >
        <Icon
          name="devicon:mysql"
          class="text-blue-400 w-10 h-10 transition-transform duration-300 transform hover:scale-110 cursor-pointer"
        />
      </a>
      <a
        class="p-2 border border-blue-700 rounded-md flex items-center justify-center hover-3d"
        title="PostgreSQL"
      >
        <Icon
          name="devicon:postgresql"
          class="text-blue-700 w-10 h-10 transition-transform duration-300 transform hover:scale-110 cursor-pointer"
        />
      </a>
      <a
        class="p-2 border border-pink-500 rounded-md flex items-center justify-center hover-3d"
        title="Figma"
      >
        <Icon
          name="devicon:figma"
          class="text-pink-500 w-10 h-10 transition-transform duration-300 transform hover:scale-110 cursor-pointer"
        />
      </a>
      <a
        class="p-2 border border-red-600 rounded-md flex items-center justify-center hover-3d"
        title="FileZilla"
      >
        <Icon
          name="devicon:filezilla"
          class="text-red-600 w-10 h-10 transition-transform duration-300 transform hover:scale-110 cursor-pointer"
        />
      </a>
      <a
        href="https://www.linkedin.com/in/danielospinaweb/"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="LinkedIn"
        class="p-2 border border-blue-600 rounded-md flex items-center justify-center hover-3d"
        title="LinkedIn"
      >
        <Icon
          name="mdi:linkedin"
          class="text-blue-600 w-10 h-10 transition-transform duration-300 transform hover:scale-110 cursor-pointer"
        />
      </a>
    </div>
    <a
      href="#contact"
      class="inline-block bg-yellow-400 hover:bg-yellow-500 text-blue-900 font-bold py-3 px-8 rounded-full shadow transition-all duration-300"
    >
      ¡Contáctame!
    </a>
  </div>
  <div
    class="absolute inset-0 bg-[url('/hero-bg.svg')] bg-cover bg-center opacity-10"
  >
  </div>
</section>
