---
// Props
export interface Props {
  id: string;
  label: string;
  type: string;
  placeholder?: string;
  value?: string;
  onInput?: (event: Event) => void;
  contentStyle?: string;
}

const {
  id,
  label,
  type = "text",
  placeholder = "",
  value = "",
  onInput,
  contentStyle = "",
} = Astro.props;
---

<div class=`flex flex-col space-y-2 ${contentStyle}` }>
  <label
    for={id}
    class="text-sm font-medium text-gray-200 shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
  >
    {label}
  </label>
  <input
    id={id}
    type={type}
    placeholder={placeholder}
    value={value}
    onInput={onInput}
    class="px-4 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
  />
</div>
