---
import { Icon } from "astro-icon/components";

// Props: label (string), type (string), onClick (function), class (string)
const {
  label = "Button",
  type = "button",
  onClick = null,
  class: className = "",
} = Astro.props;
---

<button
  type={type}
  class={`rounded-lg p-2 duration-300 ease-in-out group-hover:scale-105 px-4 py-2 bg-blue-600 text-white hover:bg-blue-700 transition ${className}`}
  {...onClick ? { onClick } : {}}
>
  {label}
  <Icon name="mdi:send" class="inline-block ml-2 w-4 h-4" />
</button>
